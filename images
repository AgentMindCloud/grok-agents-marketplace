  <script>
    // ─── Mobile nav toggle ──────────────────────────────────────
    document.querySelector('.nav-toggle')?.addEventListener('click', (e) => {
      const header = e.currentTarget.closest('header');
      header.classList.toggle('nav-open');
      const expanded = header.classList.contains('nav-open');
      e.currentTarget.setAttribute('aria-expanded', String(expanded));
    });

    // ─── Install tabs ───────────────────────────────────────────
    document.querySelectorAll('.install-tabs button').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.install-tabs button').forEach((b) => b.setAttribute('aria-selected', 'false'));
        document.querySelectorAll('.install-panel').forEach((p) => p.classList.remove('active'));
        btn.setAttribute('aria-selected', 'true');
        document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
      });
    });

    // ─── Copy buttons ───────────────────────────────────────────
    document.querySelectorAll('[data-copy], .copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const cmd = btn.dataset.copy || btn.closest('.codeblock').querySelector('code').textContent;
        try {
          await navigator.clipboard.writeText(cmd);
          const original = btn.textContent;
          btn.textContent = '✓ COPIED';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = original;
            btn.classList.remove('copied');
          }, 1500);
        } catch (e) {
          // graceful fallback — older browsers
          const ta = document.createElement('textarea');
          ta.value = cmd;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          ta.remove();
        }
      });
    });

    // ─── Live GitHub data ───────────────────────────────────────
    (async function loadGitHubData() {
      const REPO = '{{REPO_FULL_PATH}}';
      const CACHE_KEY = 'gi-gh-' + REPO;
      const CACHE_TTL = 10 * 60 * 1000; // 10 minutes

      const setEl = (sel, val) => {
        document.querySelectorAll('[data-stat="' + sel + '"]').forEach((el) => {
          el.innerHTML = val;
        });
      };

      const formatRel = (date) => {
        const diff = Date.now() - new Date(date).getTime();
        const m = Math.floor(diff / 60000);
        const h = Math.floor(diff / 3600000);
        const d = Math.floor(diff / 86400000);
        if (m < 60) return m + 'm ago';
        if (h < 24) return h + 'h ago';
        if (d < 30) return d + 'd ago';
        return Math.floor(d / 30) + 'mo ago';
      };

      const formatNum = (n) => {
        if (n >= 1000) return (n / 1000).toFixed(1) + 'k';
        return String(n);
      };

      const renderData = (data) => {
        setEl('stars', formatNum(data.stars || 0));
        setEl('forks', formatNum(data.forks || 0));
        setEl('contributors', data.contributors || '—');
        setEl('version', data.version || 'pre-release');
        setEl('version-full', data.version || 'No release yet');
        setEl('version-date', data.versionDate ? formatRel(data.versionDate) : '');
        setEl('commit-rel', data.commitRel || '—');
        setEl('commit-msg', data.commitMsg || '');
        setEl('issues', data.issues != null ? data.issues : '—');
      };

      // Try cache first
      try {
        const cached = JSON.parse(localStorage.getItem(CACHE_KEY) || 'null');
        if (cached && Date.now() - cached.t < CACHE_TTL) {
          renderData(cached.d);
          return;
        }
      } catch {}

      try {
        const [repo, release, commit, contribs] = await Promise.all([
          fetch('https://api.github.com/repos/' + REPO).then(r => r.ok ? r.json() : null),
          fetch('https://api.github.com/repos/' + REPO + '/releases/latest').then(r => r.ok ? r.json() : null).catch(() => null),
          fetch('https://api.github.com/repos/' + REPO + '/commits?per_page=1').then(r => r.ok ? r.json() : null),
          fetch('https://api.github.com/repos/' + REPO + '/contributors?per_page=100&anon=true').then(r => r.ok ? r.json() : null),
        ]);

        if (!repo) throw new Error('Repo not found');

        const data = {
          stars: repo.stargazers_count,
          forks: repo.forks_count,
          contributors: contribs ? contribs.length : null,
          issues: repo.open_issues_count,
          version: release ? release.tag_name : null,
          versionDate: release ? release.published_at : null,
          commitRel: commit && commit[0] ? formatRel(commit[0].commit.author.date) : null,
          commitMsg: commit && commit[0] ? commit[0].commit.message.split('\n')[0].slice(0, 60) : null,
        };

        localStorage.setItem(CACHE_KEY, JSON.stringify({ t: Date.now(), d: data }));
        renderData(data);
      } catch (e) {
        // Soft fail — show dashes
        renderData({});
      }
    })();

    // ─── Mermaid (lazy load when section in view) ──────────────
    (function loadMermaid() {
      const target = document.getElementById('architecture');
      if (!target) return;

      const init = async () => {
        const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs');
        mermaid.initialize({
          startOnLoad: false,
          theme: 'base',
          themeVariables: {
            primaryColor: '#0A0A0A',
            primaryTextColor: '#FFFFFF',
            primaryBorderColor: '#00F0FF',
            lineColor: '#00F0FF',
            secondaryColor: '#1a1a1a',
            tertiaryColor: '#0A0A0A',
            background: 'transparent',
            mainBkg: '#0A0A0A',
            secondBkg: '#1a1a1a',
            fontFamily: 'Inter, sans-serif',
            fontSize: '14px',
          },
          securityLevel: 'loose',
        });
        const el = document.querySelector('.mermaid');
        document.getElementById('mermaid-loading').style.display = 'none';
        el.style.display = 'block';
        await mermaid.run({ nodes: [el] });
      };

      // Lazy-load via IntersectionObserver
      if ('IntersectionObserver' in window) {
        const obs = new IntersectionObserver((entries) => {
          if (entries[0].isIntersecting) { init(); obs.disconnect(); }
        }, { rootMargin: '200px' });
        obs.observe(target);
      } else {
        init();
      }
    })();
  </script>

