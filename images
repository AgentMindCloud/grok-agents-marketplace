    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 32px;
      margin-bottom: 32px;
    }
    .footer-brand { color: var(--gi-text-muted); }
    .footer-brand strong {
      display: block;
      color: var(--gi-text); font-family: var(--gi-font-display);
      font-size: 16px; margin-bottom: 8px; letter-spacing: 1px;
