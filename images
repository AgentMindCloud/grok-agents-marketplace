    /* ═══════════════════════════════════════════════════
       FOOTER
       ═══════════════════════════════════════════════════ */
    footer.site-footer {
      border-top: 1px solid var(--gi-border);
      padding: 48px 0 32px;
      color: var(--gi-text-dim);
      font-size: 13px;
      line-height: 1.7;
