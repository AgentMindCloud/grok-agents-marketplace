  --gi-bg-elev:#0D0D0D;
  --gi-surface:rgba(255,255,255,0.04);
  --gi-surface-2:rgba(255,255,255,0.06);
  --gi-border:rgba(0,240,255,0.15);
  --gi-border-strong:rgba(0,240,255,0.40);
  --gi-border-green:rgba(0,255,157,0.40);
  --gi-border-red:rgba(255,45,85,0.40);
  --gi-text:#FFFFFF;
  --gi-text-muted:#E5E5E5;
  --gi-text-dim:rgba(255,255,255,0.5);
  --gi-text-whisper:rgba(255,255,255,0.32);
  --gi-cyan:#00F0FF;
  --gi-green:#00FF9D;
  --gi-red:#FF2D55;

  /* Type */
  --gi-font-display:'Space Grotesk',Inter,sans-serif;
  --gi-font-body:'Inter',sans-serif;
  --gi-font-mono:'JetBrains Mono','SF Mono',Consolas,monospace;

  /* Spacing scale — 4px base */
  --s-1:4px; --s-2:8px; --s-3:12px; --s-4:16px;
  --s-5:20px; --s-6:24px; --s-8:32px; --s-10:40px;
  --s-12:48px; --s-16:64px; --s-20:80px; --s-24:96px;

  /* Radius */
  --r-sm:6px; --r-md:8px; --r-lg:12px; --r-xl:16px; --r-2xl:24px; --r-full:999px;

  /* Elevation — neon glow, no drop shadows */
  --glow-cyan-sm:0 0 14px rgba(0,240,255,0.25);
  --glow-cyan-md:0 0 28px rgba(0,240,255,0.35);
  --glow-cyan-lg:0 0 60px rgba(0,240,255,0.55);
  --glow-green-md:0 0 28px rgba(0,255,157,0.35);
}

/* Reset */
*,*::before,*::after{box-sizing:border-box}
html,body{margin:0;padding:0;}
body{
  background:var(--gi-bg);color:var(--gi-text);
  font-family:var(--gi-font-body);
  -webkit-font-smoothing:antialiased;
  min-height:100vh;
}

/* Motion primitives */
@keyframes gi-pulse-trace{0%,100%{opacity:.12}50%{opacity:.42}}
@keyframes gi-pulse-node{0%,100%{opacity:.55}50%{opacity:1}}
@keyframes gi-pulse-ring{0%{opacity:.30;transform:scale(1)}70%{opacity:0;transform:scale(1.8)}100%{opacity:0;transform:scale(1.8)}}
@keyframes gi-pulse-dot{0%,100%{box-shadow:0 0 12px rgba(0,240,255,0.55)}50%{box-shadow:0 0 20px rgba(0,240,255,0.9)}}
@keyframes gi-halo{0%{opacity:.5;transform:scale(.8)}80%{opacity:0;transform:scale(1.8)}100%{opacity:0;transform:scale(1.8)}}
@keyframes gi-breathe{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.06);opacity:.92}}

/* a11y — reduce motion flattens all animations, keeps static end-state at 0.2 opacity traces */
@media (prefers-reduced-motion:reduce){
  *,*::before,*::after{animation:none!important;transition:none!important}
  .gi-trace{opacity:.2!important}
}

/* Shared primitives */
.gi-bg-glow{
  position:absolute;inset:0;pointer-events:none;
  background:radial-gradient(ellipse 55% 65% at 22% 45%, rgba(0,240,255,0.12) 0%, rgba(0,240,255,0.03) 45%, transparent 80%);
}
.gi-bg-grid{
  position:absolute;inset:0;pointer-events:none;
  background-image:
    linear-gradient(to right, rgba(0,240,255,0.045) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(0,240,255,0.045) 1px, transparent 1px);
  background-size:48px 48px;
  mask-image:radial-gradient(ellipse at 50% 50%, #000 35%, transparent 92%);
  -webkit-mask-image:radial-gradient(ellipse at 50% 50%, #000 35%, transparent 92%);
}
.gi-traces{position:absolute;inset:0;pointer-events:none}
.gi-traces svg{width:100%;height:100%;display:block}

.gi-pill{
  display:inline-flex;align-items:center;gap:8px;
  padding:6px 12px;border-radius:var(--r-full);
  background:var(--gi-surface);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border:1px solid var(--gi-border);
  font-family:var(--gi-font-body);
  font-size:11px;font-weight:500;letter-spacing:2px;
  text-transform:uppercase;color:var(--gi-text-muted);
  white-space:nowrap;
}
.gi-pill.cyan{border-color:var(--gi-border-strong);color:var(--gi-cyan)}
.gi-pill.green{border-color:var(--gi-border-green);color:var(--gi-green)}
.gi-pill.red{border-color:var(--gi-border-red);color:var(--gi-red)}
.gi-pill .gi-dot{width:6px;height:6px;border-radius:50%;background:currentColor;box-shadow:0 0 8px currentColor;opacity:.9}

.gi-btn{
  display:inline-flex;align-items:center;justify-content:center;gap:var(--s-2);
  padding:14px 22px;border-radius:var(--r-lg);
  font-family:var(--gi-font-display);
  font-size:14px;font-weight:600;letter-spacing:.3px;
  border:1px solid transparent;cursor:pointer;
  transition:all .18s ease;text-decoration:none;
  background:var(--gi-surface);color:var(--gi-text);
  border-color:var(--gi-border);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
}
.gi-btn:hover{border-color:var(--gi-border-strong);color:var(--gi-cyan)}
.gi-btn.primary{background:var(--gi-cyan);color:var(--gi-bg);border-color:transparent;box-shadow:var(--glow-cyan-sm)}
.gi-btn.primary:hover{box-shadow:var(--glow-cyan-md);transform:translateY(-1px)}
.gi-btn.success{background:var(--gi-green);color:var(--gi-bg);box-shadow:var(--glow-green-md)}
.gi-btn svg{width:16px;height:16px}

.gi-disclaimer{
  font-family:var(--gi-font-body);
  font-size:10px;letter-spacing:.3px;
  color:rgba(255,255,255,0.32);
}

/* Cert badge mini — shields.io-like */
.gi-cert{
  display:inline-flex;align-items:stretch;
  font-family:var(--gi-font-mono);
  font-size:10px;font-weight:600;letter-spacing:.2px;
  border-radius:4px;overflow:hidden;
  line-height:1;
  height:20px;
}
.gi-cert > span{display:inline-flex;align-items:center;padding:0 7px}
.gi-cert .k{background:#1a1a1a;color:rgba(255,255,255,0.65);border:1px solid rgba(255,255,255,0.1);border-right:none;border-radius:4px 0 0 4px}
.gi-cert .v{border:1px solid;border-radius:0 4px 4px 0}
.gi-cert.cyan  .v{background:rgba(0,240,255,0.12);color:var(--gi-cyan);border-color:var(--gi-border-strong)}
.gi-cert.green .v{background:rgba(0,255,157,0.12);color:var(--gi-green);border-color:var(--gi-border-green)}

/* Safety score pill */
.gi-score{
  display:inline-flex;align-items:center;gap:6px;
  padding:4px 10px;border-radius:var(--r-full);
  font-family:var(--gi-font-mono);font-size:11px;font-weight:600;
  border:1px solid;
}
.gi-score.hi{color:var(--gi-green);border-color:var(--gi-border-green);background:rgba(0,255,157,0.06)}
.gi-score.mid{color:var(--gi-text-muted);border-color:rgba(229,229,229,0.25);background:rgba(229,229,229,0.04)}
.gi-score.lo{color:var(--gi-red);border-color:var(--gi-border-red);background:rgba(255,45,85,0.06)}
.gi-score .gi-dot{width:6px;height:6px;border-radius:50%;background:currentColor;box-shadow:0 0 8px currentColor}
