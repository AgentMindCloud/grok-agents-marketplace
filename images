    .final-cta {
      text-align: center;
      padding: 80px 24px;
      background: var(--gi-surface);
      border: 1px solid var(--gi-border);
      border-radius: var(--gi-radius-lg);
      margin: 80px 0;
      position: relative;
      overflow: hidden;
    }
    .final-cta::before {
      content: '';
      position: absolute; inset: 0;
