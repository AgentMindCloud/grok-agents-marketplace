    }
    .btn-primary:hover {
      background: var(--gi-text); color: var(--gi-bg);
      box-shadow: var(--gi-cyan-glow);
      transform: translateY(-1px);
    }
    .btn-secondary {
      background: var(--gi-surface); color: var(--gi-text);
      border-color: var(--gi-border);
