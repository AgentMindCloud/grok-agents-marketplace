      color: var(--gi-text);
      background: var(--gi-surface-hover);
    }
    .codeblock {
      position: relative;
      background: #050505;
      border: 1px solid var(--gi-border);
      border-radius: var(--gi-radius-md);
      padding: 20px 56px 20px 20px;
